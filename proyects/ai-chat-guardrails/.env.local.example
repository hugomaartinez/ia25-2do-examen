# ==============================================================================
# Local Backend Configuration (Ollama)
# Copy this file to .env to use the local backend
# ==============================================================================

CHAT_MODE=ollama

# The model to use. Examples: llama3.2, mistral, phi4
# Make sure to run `ollama pull <model_name>` first!
MODEL_NAME=llama3.2

# Ollama server URL (default port is 11434)
BASE_URL=http://localhost:11434

# How many conversation turns to remember (1 turn = 1 question + 1 answer = 2 messages)
MAX_HISTORY_TURNS=10

# Maximum allowed length for user messages (in characters)
MAX_INPUT_CHARS=500
