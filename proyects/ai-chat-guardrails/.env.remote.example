# ==============================================================================
# Remote Backend Configuration (Google Gemini)
# Copy this file to .env to use the remote backend
# ==============================================================================

CHAT_MODE=gemini

# The model to use. Examples: gemini-2.5-flash, gemini-2.5-pro
MODEL_NAME=gemini-2.5-flash

# Get a free key at: https://aistudio.google.com/apikey
API_KEY=your_gemini_api_key_here

# How many conversation turns to remember (1 turn = 1 question + 1 answer = 2 messages)
MAX_HISTORY_TURNS=10

# Maximum allowed length for user messages (in characters)
MAX_INPUT_CHARS=500
